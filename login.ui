                <string notr="true">#rememberPwdCheckBox {
    color: #6b7280;
    font-size: 13px;
    spacing: 6px;
    background: transparent;
}
#rememberPwdCheckBox::indicator {
    width: 16px;
    height: 16px;
    border: 2px solid #d1d5db;
    border-radius: 3px;
